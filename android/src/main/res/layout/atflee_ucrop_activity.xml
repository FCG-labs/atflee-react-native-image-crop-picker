<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/atflee_crop_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:id="@+id/atflee_crop_shell"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <HorizontalScrollView
            android:id="@+id/atflee_crop_ratio_scroll"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#000000"
            android:fadingEdgeLength="24dp"
            android:overScrollMode="never"
            android:requiresFadingEdge="horizontal"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/atflee_crop_ratio_list"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </HorizontalScrollView>

        <FrameLayout
            android:id="@+id/atflee_crop_stage"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#000000">

            <com.yalantis.ucrop.view.UCropView
                android:id="@+id/atflee_ucrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/atflee_crop_footer"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:background="#000000">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <ImageButton
                    android:id="@+id/atflee_crop_cancel"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Cancel crop"
                    android:padding="12dp"
                    android:src="@drawable/atflee_ic_crop_close" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/atflee_crop_reset"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Reset crop rotation"
                    android:padding="11dp"
                    android:src="@drawable/atflee_ic_crop_reset" />

                <ImageButton
                    android:id="@+id/atflee_crop_rotate"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="18dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Rotate crop"
                    android:padding="11dp"
                    android:src="@drawable/atflee_ic_crop_rotate" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/atflee_crop_done"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Save crop"
                    android:padding="10dp"
                    android:src="@drawable/atflee_ic_crop_check" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/atflee_crop_loader"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:visibility="visible" />

    <View
        android:id="@+id/atflee_crop_blocking_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true" />
</FrameLayout>
